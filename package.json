{
  "name": "v2t",
  "version": "0.1.9",
  "private": true,
  "description": "Cross-platform voice-to-text desktop app MVP.",
  "author": "Haodong",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run typecheck && npm run build:native && npm run build:main && npm run build:renderer && npm run write-build-info",
    "build:native": "node scripts/build-mac-key-server.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "write-build-info": "node scripts/write-build-info.mjs",
    "package": "npm run build && node scripts/patch-osx-sign-no-timestamp.mjs && electron-builder --dir",
    "dist": "npm run build && node scripts/patch-osx-sign-no-timestamp.mjs && electron-builder --publish=never",
    "dist:win": "npm run build && electron-builder --win --publish=never",
    "preview": "vite preview --host 127.0.0.1",
    "postinstall": "node scripts/fix-key-listener-permissions.mjs",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "node-global-key-listener": "^0.3.0",
    "sherpa-onnx": "^1.12.37",
    "sherpa-onnx-node": "^1.12.40"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.haodong.v2t",
    "productName": "V2T",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": null,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-global-key-listener/**/*",
      "dist/native/**/*",
      "node_modules/sherpa-onnx/**/*",
      "node_modules/sherpa-onnx-node/**/*",
      "node_modules/sherpa-onnx-darwin-arm64/**/*",
      "node_modules/sherpa-onnx-darwin-x64/**/*",
      "node_modules/sherpa-onnx-win-x64/**/*",
      "node_modules/sherpa-onnx-win-ia32/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "Apple Development: medilleast@outlook.com (2FJL6NHLF9)",
      "timestamp": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
